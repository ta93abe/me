{
	"name": "me",
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "astro dev",
		"build": "astro build",
		"preview": "astro preview",
		"astro": "astro",
		"lint": "oxlint --fix src",
		"format": "oxfmt src",
		"test": "vitest",
		"test:ui": "vitest --ui",
		"test:run": "vitest run",
		"test:coverage": "vitest run --coverage",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"test:e2e:report": "playwright show-report",
		"deploy": "pnpm build && wrangler deploy",
		"infra:deploy": "alchemy deploy infra/alchemy.run.ts --stage prod",
		"infra:plan": "alchemy plan infra/alchemy.run.ts --stage prod"
	},
	"dependencies": {
		"@astrojs/check": "^0.9.9",
		"@astrojs/mdx": "^6.0.3",
