    "astro": "^6.4.2",
    "astro-pagefind": "^2.0.0",
    "gsap": "^3.15.0",
    "lenis": "^1.3.23",
    "remark-gfm": "^4.0.1",
    "rss-parser": "^3.13.0",
    "satori": "^0.26.0",
    "sharp": "^0.34.5",
