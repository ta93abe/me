{
	"name": "me",
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "astro dev",
		"dev:bg": "astro dev --background",
		"dev:json": "astro dev --json",
		"dev:status": "astro dev status",
		"dev:stop": "astro dev stop",
		"dev:logs": "astro dev logs",
		"dev:extra": "astro dev --ignore-lock",
		"build": "astro build",
		"preview": "astro preview",
		"astro": "astro",
		"lint": "oxlint --fix src",
		"format": "oxfmt src",
		"format:check": "oxfmt --check src",
		"check": "astro check",
		"test": "vitest",
		"test:ui": "vitest --ui",
		"test:run": "vitest run",
		"test:coverage": "vitest run --coverage",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"test:e2e:report": "playwright show-report",
		"deploy": "pnpm build && wrangler deploy",
		"infra:deploy": "alchemy deploy infra/alchemy.run.ts --stage prod",
		"infra:plan": "alchemy plan infra/alchemy.run.ts --stage prod",
		"perf:lighthouse": "node scripts/perf/lighthouse-audit.mjs",
		"perf:cwv": "node scripts/perf/collect-cwv.mjs"
	},
	"dependencies": {
		"@astrojs/check": "^0.9.9",
		"@astrojs/mdx": "^7.0.3",
		"@astrojs/react": "^6.0.1",
		"@astrojs/rss": "^4.0.19",
		"@astrojs/sitemap": "^3.7.3",
		"@fontsource/inter": "^5.2.8",
		"@fontsource/noto-serif-jp": "^5.2.8",
		"@fontsource/shippori-mincho": "^5.2.8",
		"@resvg/resvg-js": "^2.6.2",
		"@tailwindcss/typography": "^0.5.20",
		"@tailwindcss/vite": "^4.3.2",
		"astro": "^7.1.1",
		"framer-motion": "^12.42.2",
		"node-html-parser": "^7.1.0",
		"posthog-js": "^1.399.2",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"satori": "^0.26.0",
		"sharp": "^0.35.3",
		"simple-icons": "^16.26.0",
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.3.2",
		"three": "^0.185.1",
		"typescript": "^6.0.3"
	},
	"devDependencies": {
		"@effect/platform-node": "4.0.0-beta.97",
		"@playwright/test": "^1.61.1",
		"@types/node": "^25.9.5",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@types/three": "^0.185.1",
		"@vitest/ui": "^4.1.10",
		"alchemy": "2.0.0-beta.63",
		"chrome-launcher": "^1.2.1",
		"effect": "4.0.0-beta.97",
		"happy-dom": "^20.10.6",
		"lighthouse": "^12.8.2",
		"oxfmt": "^0.58.0",
		"oxlint": "^1.73.0",
		"puppeteer-core": "^24.34.0",
		"vite": "8.1.5",
		"vitest": "^4.1.10",
		"wrangler": "^4.110.0"
	}
}
