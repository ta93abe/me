---
import "../styles/global.css";
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
import PostHog from "@/components/posthog.astro";
import { SITE } from "@/config/site";
import { generateWebSiteSchema, stringifySchema } from "@/utils/schema";

interface Props {
	title?: string;
	description?: string;
	ogImage?: string;
	ogImageAlt?: string;
	ogSiteName?: string;
	ogType?: "website" | "article" | "book";
	/** 明示的な canonical。未指定時は現在の pathname */
	canonicalURL?: string | URL;
	/** true のとき検索エンジンにインデックスさせない */
	noindex?: boolean;
	noHeader?: boolean;
	noFooter?: boolean;
	/** true のときメイン先頭のヘッダー分パディングを付けない（フルブリード用） */
	flushTop?: boolean;
	/** true のときビューポートに固定しスクロールを無効化 */
	lockViewport?: boolean;
}

const {
	title = SITE.name,
	description = SITE.description,
	ogImage = "/og/default.png",
	ogImageAlt = title,
	ogSiteName = SITE.name,
	ogType = "website",
	canonicalURL: canonicalOverride,
	noindex = false,
	noHeader = false,
	noFooter = false,
	flushTop = false,
	lockViewport = false,
} = Astro.props;

const canonicalURL = canonicalOverride
	? new URL(canonicalOverride, Astro.site)
	: new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(ogImage, Astro.site);
const robotsContent = noindex ? "noindex, nofollow" : "index, follow";
---

<!doctype html>
<html lang="ja">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<meta name="color-scheme" content="light" />
		<meta name="theme-color" content="#ffffff" />

		<!-- Primary Meta Tags -->
		<title>{title}</title>
		<meta name="title" content={title} />
		<meta name="description" content={description} />
		<meta name="author" content={SITE.author} />
		<meta name="robots" content={robotsContent} />
		<link rel="canonical" href={canonicalURL} />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content={ogType} />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={ogImageURL} />
		<meta property="og:image:alt" content={ogImageAlt} />
		<meta property="og:site_name" content={ogSiteName} />
		<meta property="og:locale" content={SITE.locale} />

		<!-- Twitter -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:site" content={SITE.twitter} />
		<meta name="twitter:creator" content={SITE.twitter} />
		<meta name="twitter:url" content={canonicalURL} />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageURL} />
		<meta name="twitter:image:alt" content={ogImageAlt} />

		<!-- 構造化データ (JSON-LD) -->
		<script
			type="application/ld+json"
			set:html={stringifySchema(
				generateWebSiteSchema(Astro.site?.href || SITE.url),
			)}
		></script>
		<slot name="head" />
		<PostHog />
		<noscript>
			<style>
				[data-animate] {
					opacity: 1 !important;
					transform: none !important;
				}
			</style>
		</noscript>
	</head>
	<body class:list={["transition-colors", { "lock-viewport": lockViewport }]}>
		<!-- スキップリンク -->
		<a href="#main-content" class="skip-link">
			コンテンツにスキップ
		</a>
		{!noHeader && <Header />}
		<div id="main-content" class:list={[{ "main-flush": flushTop }]}>
			<slot />
		</div>
		{!noFooter && <Footer />}
		<script>
			import "../scripts/animations/observer.ts";
		</script>
		<script>
			import "../scripts/model-context";
		</script>
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		min-height: 100%;
	}

	#main-content:not(.main-flush) {
		padding-top: var(--header-height);
	}

	body.lock-viewport {
		height: 100dvh;
		height: 100svh;
		overflow: hidden;
		overscroll-behavior: none;
	}

	:global(html:has(body.lock-viewport)) {
		height: 100%;
		overflow: hidden;
		overscroll-behavior: none;
	}

	body.lock-viewport #main-content {
		height: 100%;
		overflow: hidden;
	}

	body.lock-viewport :global(footer) {
		position: fixed;
		inset-inline: 0;
		bottom: 0;
		z-index: 50;
	}

	body.lock-viewport :global(footer) > div {
		padding-block: 1.25rem;
	}

	/* スキップリンク */
	.skip-link {
		position: absolute;
		top: -100%;
		left: 50%;
		transform: translateX(-50%);
		padding: 0.75rem 1.5rem;
		background: var(--primary-color);
		color: white;
		font-weight: 600;
		border-radius: 0 0 0.5rem 0.5rem;
		text-decoration: none;
		z-index: 50;
		transition: top 0.2s ease-out;
	}

	.skip-link:focus-visible {
		top: 0;
	}

	@media (prefers-reduced-motion: reduce) {
		.skip-link {
			transition: none;
		}
	}
</style>
