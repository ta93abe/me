---
// タグフィルタリングコンポーネント
// クライアントサイドでリストのフィルタを行う

interface Props {
	tags: string[];
	containerId: string;
}

const { tags, containerId } = Astro.props;

// 重複を排除してソート
const uniqueTags = [...new Set(tags)].toSorted();
---

{
	uniqueTags.length > 0 && (
		<div class="mb-8 space-y-4" data-filter-sort data-container={containerId}>
			<div class="flex flex-wrap items-center gap-2">
				<span class="text-sm font-medium text-(--text-muted)">タグ:</span>
				<button type="button" class="filter-chip active" data-tag="all">
					すべて
				</button>
				{uniqueTags.map((tag) => (
					<button type="button" class="filter-chip" data-tag={tag}>
						{tag}
					</button>
				))}
			</div>

			<div class="active-filter-area hidden items-center gap-2">
				<span class="text-sm text-(--text-muted)">選択中:</span>
				<span class="active-filter-tag inline-flex items-center gap-1 rounded-full bg-(--primary-color) px-3 py-1 text-sm font-medium text-white"></span>
				<button
					type="button"
					class="reset-filter-btn ml-2 text-sm text-(--text-muted) underline transition-colors hover:text-(--text-primary)"
				>
					リセット
				</button>
			</div>

			<div class="text-sm text-(--text-muted)">
				<span class="result-count"></span>
			</div>

			<div class="empty-state hidden py-12 text-center" role="status" aria-live="polite">
				<p class="mb-4 text-sm text-(--text-muted)">
					該当する項目がありません
				</p>
				<button
					type="button"
					class="reset-all-btn rounded-full bg-(--primary-color)/10 px-4 py-2 text-sm font-medium text-(--primary-color) transition-colors hover:bg-(--primary-color) hover:text-white"
				>
					フィルターをリセット
				</button>
			</div>
		</div>
	)
}

<style>
	.filter-chip {
		display: inline-flex;
		align-items: center;
		gap: 0.25rem;
		padding: 0.125rem 0;
		font-size: 0.875rem;
		color: var(--text-muted);
		background: transparent;
		border: none;
		transition: color 0.15s ease;
	}

	.filter-chip:hover {
		color: var(--text-primary);
	}

	.filter-chip:focus-visible {
		outline: 2px solid var(--primary-color);
		outline-offset: 2px;
	}

	.filter-chip.active {
		color: var(--text-primary);
		font-weight: 600;
	}

	[data-item] {
		transition: opacity 0.15s ease;
	}

	[data-item].filter-hidden {
		opacity: 0;
		pointer-events: none;
		position: absolute;
		visibility: hidden;
	}

	@media (prefers-reduced-motion: reduce) {
		.filter-chip,
		[data-item] {
			transition: none;
		}
	}
</style>

<script>
	import "../scripts/filter-sort";
</script>
