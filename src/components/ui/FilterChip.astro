---
import { tv } from "tailwind-variants";

const filterChip = tv({
	base: "inline-flex items-center gap-1 rounded-full px-3 py-1 text-sm font-medium transition-all duration-200",
	variants: {
		active: {
			true: "bg-[var(--primary-color)] text-white",
			false:
				"bg-[var(--bg-elevated)] text-[var(--text-secondary)] hover:bg-[var(--bg-tertiary)] hover:text-[var(--primary-color)]",
		},
	},
	defaultVariants: {
		active: false,
	},
});

interface Props {
	active?: boolean;
	tag: string;
	class?: string;
}

const { active = false, tag, class: className = "" } = Astro.props;

const classes = filterChip({ active, class: className });
---

<button type="button" class={classes} data-tag={tag}>
	<slot />
</button>

<style>
	button:focus-visible {
		outline: 2px solid var(--primary-color);
		outline-offset: 2px;
	}
</style>
