---
import { tv } from "tailwind-variants";

const navLink = tv({
	base: "relative font-medium transition-colors duration-200 hover:text-(--text-primary) text-(--text-secondary)",
	variants: {
		active: {
			true: "text-(--text-primary)",
			false: "",
		},
	},
	defaultVariants: {
		active: false,
	},
});

interface Props {
	href: string;
	active?: boolean;
	class?: string;
}

const { href, active, class: className = "" } = Astro.props;

const currentPath = Astro.url.pathname;

// 自動でアクティブ状態を検出（propsで明示的に指定されていない場合）
const isActive =
	active !== undefined
		? active
		: href === "/"
			? currentPath === "/"
			: currentPath.startsWith(href);

const classes = navLink({ active: isActive, class: className });
---

<a
	href={href}
	class={classes}
	aria-current={isActive ? "page" : undefined}
>
	<slot />
	{isActive && <span class="absolute -bottom-1 left-0 h-0.5 w-full rounded-full bg-gradient-to-r from-(--primary-color) to-(--accent-color)" aria-hidden="true" />}
</a>
