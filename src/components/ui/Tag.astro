---
const variantStyles = {
	default: "bg-neutral-800 text-neutral-300",
	success: "bg-green-950/40 text-green-300",
	warning: "bg-yellow-950/40 text-yellow-300",
	info: "bg-blue-950/40 text-blue-300",
};

interface Props {
	variant?: keyof typeof variantStyles;
	class?: string;
}

const { variant = "default", class: className = "" } = Astro.props;
---

<span
  class:list={[
    "rounded-full px-3 py-1 text-xs",
    variantStyles[variant],
    className,
  ]}
>
  <slot />
</span>
