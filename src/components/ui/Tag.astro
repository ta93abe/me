---
import { cn } from "@/utils/cn";

const variantStyles = {
	default: "text-(--text-muted)",
	success: "text-emerald-700",
	warning: "text-amber-800",
	info: "text-(--primary-color)",
};

interface Props {
	variant?: keyof typeof variantStyles;
	class?: string;
}

const { variant = "default", class: className = "" } = Astro.props as Props;
const classes = cn("text-xs", variantStyles[variant], className);
---

<span class:list={[classes]}><slot /></span>
