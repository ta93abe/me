---
import { statusLabels, statusStyles } from "@/utils/books";
import { cn } from "@/utils/cn";

interface Props {
  variant?: keyof typeof statusLabels;
  class?: string;
}

const { variant = "reading", class: className = "" } = Astro.props as Props;
const classes = cn(
  "text-xs font-medium",
  statusStyles[variant],
  className,
);
---

<span class:list={[classes]}>{statusLabels[variant]}</span>
