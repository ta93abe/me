---
import { cn } from "../utils/cn";

export interface Props {
	variant?: "text" | "title" | "card" | "image" | "circle";
	className?: string;
	width?: string;
	height?: string;
}

const { variant = "text", className = "", width, height } = Astro.props as Props;

const variantClasses = {
	text: "h-4 rounded",
	title: "h-8 rounded",
	card: "h-32 rounded-lg",
	image: "aspect-video rounded-lg",
	circle: "rounded-full",
};

const variantClass = variantClasses[variant];
const classes = cn("animate-pulse bg-[var(--bg-tertiary)]", variantClass, className);

let style = "";
if (width) {
	style += `width: ${width};`;
}
if (height) {
	style += `height: ${height};`;
}
---

<div
  class={classes}
  style={style}
  role="status"
  aria-label="読み込み中"
>
  <span class="sr-only">読み込み中...</span>
</div>
