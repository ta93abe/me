---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import type { MediaType } from "@/utils/creative-media";

interface Props {
	mediaType: MediaType;
	title: string;
	coverImage?: ImageMetadata;
	audio?: string;
	variant?: "card" | "detail" | "gallery";
	class?: string;
}

const {
	mediaType,
	title,
	coverImage,
	audio,
	variant = "card",
	class: className = "",
} = Astro.props;

const isMusic = mediaType === "music";
const showPlayer = isMusic && Boolean(audio) && variant !== "card";
---

<div
	class:list={[
		"piece-media",
		`piece-media--${variant}`,
		`piece-media--${mediaType}`,
		className,
	]}
>
	{
		coverImage ? (
			<Image
				src={coverImage}
				alt={title}
				class="piece-media-image"
			/>
		) : (
			<div class="piece-media-placeholder" aria-hidden="true">
				{isMusic ? (
					<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
						<path
							stroke-linecap="round"
							stroke-linejoin="round"
							d="M9 18V5l12-2v13M9 18a3 3 0 11-6 0 3 3 0 016 0zm12-2a3 3 0 11-6 0 3 3 0 016 0z"
						/>
					</svg>
				) : (
					<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
						<path
							stroke-linecap="round"
							stroke-linejoin="round"
							d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"
						/>
					</svg>
				)}
			</div>
		)
	}

	{
		isMusic && variant === "card" && (
			<span class="piece-media-note" aria-hidden="true">♪</span>
		)
	}

	{
		showPlayer && audio && (
			<div class="piece-media-player">
				<audio controls preload="metadata" src={audio}>
					<a href={audio}>音声ファイルを開く</a>
				</audio>
			</div>
		)
	}
</div>

<style>
	.piece-media {
		position: relative;
		overflow: hidden;
		background: var(--bg-secondary);
	}

	.piece-media--card {
		width: 100%;
		height: 100%;
	}

	.piece-media--detail,
	.piece-media--gallery {
		width: 100%;
	}

	.piece-media-image {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}

	.piece-media--photo .piece-media-image {
		filter: saturate(0.92) contrast(1.04);
	}

	.piece-media--drawing .piece-media-image {
		filter: saturate(0.85) contrast(1.05);
	}

	.piece-media-placeholder {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 100%;
		height: 100%;
		min-height: 10rem;
		color: var(--text-muted);
		background:
			radial-gradient(circle at 30% 30%, rgba(168, 146, 196, 0.18), transparent 55%),
			linear-gradient(160deg, #16141c, #0e0e12);
	}

	.piece-media-placeholder svg {
		width: 2.5rem;
		height: 2.5rem;
		opacity: 0.7;
	}

	.piece-media-note {
		position: absolute;
		right: 0.65rem;
		bottom: 0.45rem;
		font-size: 1.1rem;
		color: rgba(255, 255, 255, 0.7);
		text-shadow: 0 1px 8px rgba(0, 0, 0, 0.45);
		pointer-events: none;
	}

	.piece-media-player {
		position: absolute;
		left: 0;
		right: 0;
		bottom: 0;
		padding: 0.85rem 1rem;
		background: linear-gradient(transparent, rgba(0, 0, 0, 0.72));
	}

	.piece-media-player audio {
		width: 100%;
		height: 2.25rem;
	}

	.piece-media--music.piece-media--detail,
	.piece-media--music.piece-media--gallery {
		min-height: 16rem;
		aspect-ratio: 16 / 9;
	}

	.piece-media--music.piece-media--detail .piece-media-placeholder,
	.piece-media--music.piece-media--gallery .piece-media-placeholder {
		min-height: 16rem;
	}
</style>
