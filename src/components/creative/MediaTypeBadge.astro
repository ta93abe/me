---
import {
	getMediaTypeLabel,
	type MediaType,
} from "@/utils/creative-media";

interface Props {
	mediaType: MediaType;
	class?: string;
}

const { mediaType, class: className = "" } = Astro.props;
const label = getMediaTypeLabel(mediaType);
---

<span class={`media-type ${className}`.trim()}>
	{label}
</span>

<style>
	.media-type {
		font-size: 0.8125rem;
		color: var(--text-muted);
	}
</style>
