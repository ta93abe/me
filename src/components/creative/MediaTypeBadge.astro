---
import {
	getMediaTypeLabel,
	type MediaType,
} from "../../utils/creative-media";

interface Props {
	mediaType: MediaType;
	class?: string;
}

const { mediaType, class: className = "" } = Astro.props;
const label = getMediaTypeLabel(mediaType);
---

<span class={`media-type media-type--${mediaType} ${className}`.trim()}>
	{label}
</span>

<style>
	.media-type {
		display: inline-block;
		padding: 0.15rem 0.5rem;
		font-size: 0.7rem;
		letter-spacing: 0.08em;
		line-height: 1.4;
		border: 1px solid currentColor;
	}

	.media-type--drawing {
		color: #c4a484;
	}

	.media-type--photo {
		color: #8aa4b8;
	}

	.media-type--music {
		color: #a892c4;
	}
</style>
