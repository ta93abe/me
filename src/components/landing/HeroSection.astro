---
import Button from "@/components/ui/Button.astro";
---

<section id="hero" class="hero-section">
	<div class="hero-content">
		<h1 class="hero-title font-display" data-animate>ta93abe</h1>

		<p class="hero-description" data-animate>
			コードとデザインの間で、<br class="sm:hidden" />面白いものを作っています。
		</p>

		<div class="hero-cta" data-animate="stagger">
			<Button href="/gallery" variant="primary" size="lg">View Gallery</Button>
			<Button href="/links" variant="secondary" size="lg">Links</Button>
		</div>
	</div>
</section>

<style>
	.hero-section {
		min-height: calc(100dvh - var(--header-height));
		display: flex;
		align-items: center;
		justify-content: center;
		background: var(--bg-primary);
	}

	.hero-content {
		text-align: center;
		padding: 2rem;
		max-width: 40rem;
	}

	.hero-title {
		font-size: clamp(3rem, 12vw, 5rem);
		font-weight: 700;
		line-height: 1.1;
		margin: 0 0 1.5rem;
		color: var(--text-primary);
		letter-spacing: -0.02em;
	}

	.hero-description {
		font-size: clamp(1rem, 2.5vw, 1.25rem);
		color: var(--text-secondary);
		margin: 0 0 2rem;
		line-height: 1.8;
	}

	.hero-cta {
		display: flex;
		gap: 0.75rem;
		justify-content: center;
		flex-wrap: wrap;
	}

	@media (max-width: 768px) {
		.hero-section {
			min-height: calc(100svh - var(--header-height));
		}
	}
</style>

<script is:inline>
	document.querySelectorAll(".hero-cta a").forEach(function(btn) {
		btn.addEventListener("click", function() {
			window.posthog?.capture("hero_cta_clicked", {
				cta_label: btn.textContent?.trim(),
				cta_href: btn.getAttribute("href"),
			});
		});
	});
</script>
