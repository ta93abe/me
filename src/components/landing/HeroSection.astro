---
// ヒーローセクション
import Button from "@/components/ui/Button.astro";
---

<section id="hero" class="hero-section">
  <!-- Animated background orbs -->
  <div class="hero-orb hero-orb-1" aria-hidden="true"></div>
  <div class="hero-orb hero-orb-2" aria-hidden="true"></div>
  <div class="hero-orb hero-orb-3" aria-hidden="true"></div>

  <!-- Grid pattern overlay -->
  <div class="hero-grid" aria-hidden="true"></div>

  <div class="hero-content">
    <div class="hero-badge" data-animate>
      <span class="hero-badge-dot"></span>
      <span>Software Engineer & Creative Developer</span>
    </div>

    <h1 class="hero-title" data-animate>
      <span class="hero-name">ta93abe</span>
    </h1>

    <p class="hero-description" data-animate>
      コードとデザインの間で、<br class="sm:hidden" />面白いものを作っています。
    </p>

    <div class="hero-cta" data-animate="stagger">
      <Button href="/gallery" variant="primary" size="lg">View Gallery</Button>
      <Button href="/links" variant="secondary" size="lg">Links</Button>
    </div>
  </div>
</section>

<style>
  .hero-section {
    position: relative;
    /* sticky ヘッダーの高さを差し引いて 1 画面に収める */
    min-height: calc(100dvh - var(--header-height));
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background:
      radial-gradient(ellipse at 50% 0%, rgba(166, 61, 42, 0.06) 0%, transparent 50%),
      var(--bg-primary);
  }

  .hero-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(28, 27, 25, 0.035) 1px, transparent 1px),
      linear-gradient(90deg, rgba(28, 27, 25, 0.035) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse at center, black 0%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse at center, black 0%, transparent 70%);
    pointer-events: none;
  }

  .hero-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.22;
    pointer-events: none;
    will-change: transform;
  }

  .hero-orb-1 {
    width: 500px;
    height: 500px;
    background: linear-gradient(135deg, #f0e6dc, #e8cfc0);
    top: -150px;
    right: -100px;
    animation: float 12s ease-in-out infinite;
  }

  .hero-orb-2 {
    width: 400px;
    height: 400px;
    background: linear-gradient(135deg, #ebe8e0, #ddd6c8);
    bottom: -100px;
    left: -100px;
    animation: float 14s ease-in-out infinite reverse;
  }

  .hero-orb-3 {
    width: 300px;
    height: 300px;
    background: linear-gradient(135deg, #ead8cf, #dcc0b4);
    top: 40%;
    left: 30%;
    opacity: 0.18;
    animation: float 16s ease-in-out infinite;
  }

  @keyframes float {
    0%, 100% {
      transform: translate(0, 0) scale(1);
    }
    33% {
      transform: translate(30px, -40px) scale(1.05);
    }
    66% {
      transform: translate(-20px, 30px) scale(0.95);
    }
  }

  .hero-content {
    position: relative;
    z-index: 10;
    text-align: center;
    padding: 2rem;
    max-width: 900px;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    border-radius: 9999px;
    background: rgba(28, 27, 25, 0.05);
    font-size: 0.8125rem;
    color: var(--text-secondary);
    margin-bottom: 2rem;
    backdrop-filter: blur(8px);
  }

  .hero-badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--primary-color);
    box-shadow: 0 0 8px rgba(166, 61, 42, 0.5);
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }

  .hero-title {
    font-size: clamp(4rem, 15vw, 10rem);
    font-weight: 700;
    line-height: 0.9;
    margin: 0;
    letter-spacing: -0.04em;
  }

  .hero-name {
    display: inline-block;
    background: linear-gradient(135deg, var(--text-primary) 0%, var(--primary-color) 50%, var(--accent-color) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    filter: drop-shadow(0 2px 24px rgba(28, 27, 25, 0.08));
  }

  .hero-description {
    font-size: clamp(1.125rem, 2.5vw, 1.5rem);
    color: var(--text-secondary);
    margin: 2rem 0 2.5rem;
    font-weight: 400;
    line-height: 1.7;
  }

  .hero-cta {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  @media (max-width: 768px) {
    .hero-section {
      min-height: calc(100svh - var(--header-height));
    }

    .hero-orb-1 {
      width: 300px;
      height: 300px;
    }

    .hero-orb-2 {
      width: 250px;
      height: 250px;
    }

    .hero-orb-3 {
      width: 200px;
      height: 200px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-orb,
    .hero-badge-dot {
      animation: none;
    }
  }
</style>

<script is:inline>
  document.querySelectorAll(".hero-cta a").forEach(function(btn) {
    btn.addEventListener("click", function() {
      window.posthog?.capture("hero_cta_clicked", {
        cta_label: btn.textContent?.trim(),
        cta_href: btn.getAttribute("href"),
      });
    });
  });
</script>
