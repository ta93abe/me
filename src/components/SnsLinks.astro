const categories = [...new Set(snsLinks.map((link) => link.category))];
---

<div class="sns-links space-y-14">
	{
		categories.map((category) => (
			<section data-animate>
				<div class="mb-5 flex items-center gap-4">
					<div class="h-px flex-1 bg-neutral-200" />
					<h2 class="font-display text-sm font-bold uppercase tracking-widest text-neutral-400">
						{category}
					</h2>
					<div class="h-px flex-1 bg-neutral-200" />
				</div>

				<div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
					{snsLinks
						.filter((link) => link.category === category)
						.map((link) => (
							<a
								href={link.url}
								target="_blank"
								rel="noopener noreferrer"
								class={`group relative flex items-center gap-4 overflow-hidden rounded-2xl border border-neutral-200 bg-white p-4 transition-all duration-300 hover:-translate-y-1 hover:shadow-xl focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--primary-color)] ${link.hoverBg}`}
								aria-label={link.name}
							>
								<div class="relative flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-xl bg-neutral-50 transition-colors duration-300 group-hover:bg-white">
									<svg
										viewBox={link.viewBox || "0 0 24 24"}
										class="h-6 w-6"
										aria-hidden="true"
									>
										{link.gradient && (
											<defs>
												{link.gradient.type === "radial" ? (
													<radialGradient
														id={link.gradient.id}
														cx="30%"
														cy="107%"
														r="150%"
													>
														{link.gradient.stops.map((stop) => (
															<stop offset={stop.offset} stop-color={stop.color} />
														))}
													</radialGradient>
												) : (
													<linearGradient id={link.gradient.id}>
														{link.gradient.stops.map((stop) => (
															<stop offset={stop.offset} stop-color={stop.color} />
														))}
													</linearGradient>
												)}
											</defs>
										)}
										{Array.isArray(link.icon) ? (
											link.icon.map((p, i) => (
												<path
													d={p.path}
													fill={p.color}
													transform={
														link.name === "TikTok"
															? i === 0
																? "translate(0.5, 0.3)"
																: i === 1
																	? "translate(-0.5, -0.3)"
																	: undefined
														: undefined
													}
												/>
											))
										) : link.stroke ? (
											<path
												d={link.icon as string}
												fill="none"
												stroke={link.stroke.color}
												stroke-width={link.stroke.width}
												stroke-linecap="round"
												stroke-linejoin="round"
											/>
										) : link.gradient ? (
											<path d={link.icon} fill={`url(#${link.gradient.id})`} />
										) : (
											<path d={link.icon} fill={link.color} />
										)}
									</svg>
								</div>

								<div class="min-w-0 flex-1">
									<div class="text-base font-bold text-neutral-900 transition-colors group-hover:text-[var(--primary-color)]">
										{link.name}
									</div>
									<div class="truncate text-xs text-neutral-500">
										{link.url.replace(/^https:\/\//, "")}
									</div>
								</div>

								<svg
									class="h-4 w-4 flex-shrink-0 text-neutral-300 transition-all duration-300 group-hover:translate-x-1 group-hover:text-neutral-500"
									fill="none"
									viewBox="0 0 24 24"
									stroke="currentColor"
									aria-hidden="true"
								>
									<path
										stroke-linecap="round"
										stroke-linejoin="round"
										stroke-width={2}
										d="M7 17L17 7M17 7H7M17 7v10"
									/>
								</svg>
							</a>
						))}
				</div>
			</section>
		))
	}
</div>

<script is:inline>
	document.querySelectorAll(".sns-links a[href]").forEach(function (link) {
		link.addEventListener("click", function () {
			window.posthog?.capture("sns_link_clicked", {
				platform: link.getAttribute("aria-label"),
				url: link.getAttribute("href"),
			});
		});
	});
</script>
