---
import * as simpleIcons from "simple-icons";
import type { SimpleIcon } from "simple-icons";
import { CUSTOM_ICONS } from "@/data/custom-icons";
import linksData from "@/data/links.json";

interface ResolvedIcon {
	path: string;
	hex: string;
	viewBox: string;
	stroke?: {
		color: string;
		width: string;
	};
}

const resolveIcon = (slug: string): ResolvedIcon => {
	const custom = CUSTOM_ICONS[slug];
	if (custom) {
		return {
			path: custom.path,
			hex: custom.hex,
			viewBox: custom.viewBox ?? "0 0 24 24",
			stroke: custom.stroke,
		};
	}

	const key = `si${slug.charAt(0).toUpperCase()}${slug.slice(1)}`;
	const icon = (simpleIcons as unknown as Record<string, SimpleIcon>)[key];
	if (!icon) {
		throw new Error(
			`Unknown icon slug "${slug}". simple-icons のスラッグを指定するか、src/data/custom-icons.ts に追加してください。`,
		);
	}
	return { path: icon.path, hex: `#${icon.hex}`, viewBox: "0 0 24 24" };
};

const links = linksData.links.map((link) => ({
	...link,
	iconData: resolveIcon(link.icon),
}));
---

<ul class="sns-links sns-grid">
	{
		links.map((link) => (
			<li>
				<a
					href={link.url}
					target="_blank"
					rel="noopener noreferrer"
					class="sns-card"
					aria-label={link.name}
				>
					<svg
						viewBox={link.iconData.viewBox}
						class="sns-card-icon"
						aria-hidden="true"
					>
						{link.iconData.stroke ? (
							<path
								d={link.iconData.path}
								fill="none"
								stroke={link.iconData.stroke.color}
								stroke-width={link.iconData.stroke.width}
								stroke-linecap="round"
								stroke-linejoin="round"
							/>
						) : (
							<path d={link.iconData.path} fill={link.iconData.hex} />
						)}
					</svg>
					<span class="sns-card-name">{link.name}</span>
				</a>
			</li>
		))
	}
</ul>

<style>
	.sns-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 0.5rem;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	@media (min-width: 640px) {
		.sns-grid {
			grid-template-columns: repeat(5, 1fr);
			gap: 0.625rem;
		}
	}

	@media (min-width: 1024px) {
		.sns-grid {
			grid-template-columns: repeat(6, 1fr);
		}
	}

	.sns-card {
		display: flex;
		aspect-ratio: 1 / 1;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 0.4rem;
		padding: 0.5rem;
		text-decoration: none;
		color: inherit;
		background: var(--bg-secondary);
		transition:
			background-color 0.15s ease,
			color 0.15s ease;
	}

	.sns-card:hover {
		background: var(--bg-tertiary);
		color: var(--primary-color);
	}

	.sns-card-icon {
		width: 1.25rem;
		height: 1.25rem;
		flex-shrink: 0;
	}

	.sns-card-name {
		font-size: 0.6875rem;
		font-weight: 500;
		line-height: 1.3;
		text-align: center;
		color: var(--text-primary);
		overflow: hidden;
		display: -webkit-box;
		-webkit-box-orient: vertical;
		-webkit-line-clamp: 2;
	}

	.sns-card:hover .sns-card-name {
		color: inherit;
	}
</style>

<script>
	document.querySelectorAll(".sns-links a[href]").forEach((link) => {
		link.addEventListener("click", () => {
			window.posthog?.capture("sns_link_clicked", {
				platform: link.getAttribute("aria-label"),
				url: link.getAttribute("href"),
			});
		});
	});
</script>
