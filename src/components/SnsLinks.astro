---
// SNSリンク集コンポーネント
import * as simpleIcons from "simple-icons";
import type { SimpleIcon } from "simple-icons";
import { CUSTOM_ICONS } from "@/data/custom-icons";
import linksData from "@/data/links.json";

interface ResolvedIcon {
	path: string;
	hex: string;
	viewBox: string;
	stroke?: {
		color: string;
		width: string;
	};
}

const resolveIcon = (slug: string): ResolvedIcon => {
	const custom = CUSTOM_ICONS[slug];
	if (custom) {
		return {
			path: custom.path,
			hex: custom.hex,
			viewBox: custom.viewBox ?? "0 0 24 24",
			stroke: custom.stroke,
		};
	}

	const key = `si${slug.charAt(0).toUpperCase()}${slug.slice(1)}`;
	const icon = (simpleIcons as unknown as Record<string, SimpleIcon>)[key];
	if (!icon) {
		throw new Error(
			`Unknown icon slug "${slug}". simple-icons のスラッグを指定するか、src/data/custom-icons.ts に追加してください。`,
		);
	}
	return { path: icon.path, hex: `#${icon.hex}`, viewBox: "0 0 24 24" };
};

const links = linksData.links.map((link) => ({
	...link,
	iconData: resolveIcon(link.icon),
}));

const categories = [...new Set(links.map((link) => link.category))];
---

<div class="sns-links space-y-10">
	{
		categories.map((category) => (
			<section>
				<h2 class="mb-4 text-sm font-medium text-(--text-muted)">{category}</h2>

				<ul class="space-y-1">
					{links
						.filter((link) => link.category === category)
						.map((link) => (
							<li>
								<a
									href={link.url}
									target="_blank"
									rel="noopener noreferrer"
									class="flex items-center gap-4 py-4 transition-colors hover:text-(--primary-color) focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-(--primary-color)"
									aria-label={link.name}
								>
									<svg
										viewBox={link.iconData.viewBox}
										class="h-5 w-5 shrink-0"
										aria-hidden="true"
									>
										{link.iconData.stroke ? (
											<path
												d={link.iconData.path}
												fill="none"
												stroke={link.iconData.stroke.color}
												stroke-width={link.iconData.stroke.width}
												stroke-linecap="round"
												stroke-linejoin="round"
											/>
										) : (
											<path d={link.iconData.path} fill={link.iconData.hex} />
										)}
									</svg>

									<span class="min-w-0 flex-1">
										<span class="block font-medium text-(--text-primary)">{link.name}</span>
										<span class="block truncate text-xs text-(--text-muted)">
											{link.url.replace(/^https:\/\//, "")}
										</span>
									</span>
								</a>
							</li>
						))}
				</ul>
			</section>
		))
	}
</div>

<script is:inline>
	document.querySelectorAll(".sns-links a[href]").forEach(function (link) {
		link.addEventListener("click", function () {
			window.posthog?.capture("sns_link_clicked", {
				platform: link.getAttribute("aria-label"),
				url: link.getAttribute("href"),
			});
		});
	});
</script>
