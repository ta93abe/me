---
// SNSリンク集コンポーネント
// - リンクデータ: src/data/links.json（Sveltia CMS から編集可能）
// - アイコン: simple-icons（各サービスのブランドガイドライン由来の公式 SVG と色）
//   simple-icons 未収録のサービスのみ src/data/custom-icons.ts でフォールバック
import * as simpleIcons from "simple-icons";
import type { SimpleIcon } from "simple-icons";
import { CUSTOM_ICONS } from "@/data/custom-icons";
import linksData from "@/data/links.json";

interface ResolvedIcon {
	path: string;
	hex: string;
	viewBox: string;
	stroke?: {
		color: string;
		width: string;
	};
}

const resolveIcon = (slug: string): ResolvedIcon => {
	const custom = CUSTOM_ICONS[slug];
	if (custom) {
		return {
			path: custom.path,
			hex: custom.hex,
			viewBox: custom.viewBox ?? "0 0 24 24",
			stroke: custom.stroke,
		};
	}

	const key = `si${slug.charAt(0).toUpperCase()}${slug.slice(1)}`;
	const icon = (simpleIcons as unknown as Record<string, SimpleIcon>)[key];
	if (!icon) {
		throw new Error(
			`Unknown icon slug "${slug}". simple-icons のスラッグを指定するか、src/data/custom-icons.ts に追加してください。`,
		);
	}
	return { path: icon.path, hex: `#${icon.hex}`, viewBox: "0 0 24 24" };
};

const links = linksData.links.map((link) => ({
	...link,
	iconData: resolveIcon(link.icon),
}));

const categories = [...new Set(links.map((link) => link.category))];
---

<div class="sns-links space-y-14">
	{
		categories.map((category) => (
			<section data-animate>
				<div class="mb-5 flex items-center gap-4">
					<div class="h-px flex-1 bg-(--border-color)" />
					<h2 class="font-display text-sm font-bold uppercase tracking-widest text-(--text-muted)">
						{category}
					</h2>
					<div class="h-px flex-1 bg-(--border-color)" />
				</div>

				<div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
					{links
						.filter((link) => link.category === category)
						.map((link) => (
							<a
								href={link.url}
								target="_blank"
								rel="noopener noreferrer"
								class="group relative flex items-center gap-4 overflow-hidden rounded-2xl bg-(--bg-tertiary) p-4 transition-all duration-300 hover:-translate-y-1 hover:bg-(--bg-elevated) focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-(--primary-color)"
								aria-label={link.name}
							>
								<div class="relative flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-xl bg-(--bg-secondary) transition-colors duration-300 group-hover:bg-(--bg-elevated)">
									<svg
										viewBox={link.iconData.viewBox}
										class="h-6 w-6"
										aria-hidden="true"
									>
										{link.iconData.stroke ? (
											<path
												d={link.iconData.path}
												fill="none"
												stroke={link.iconData.stroke.color}
												stroke-width={link.iconData.stroke.width}
												stroke-linecap="round"
												stroke-linejoin="round"
											/>
										) : (
											<path d={link.iconData.path} fill={link.iconData.hex} />
										)}
									</svg>
								</div>

								<div class="min-w-0 flex-1">
									<div class="text-base font-bold text-(--text-primary) transition-colors group-hover:text-(--primary-color)">
										{link.name}
									</div>
									<div class="truncate text-xs text-(--text-muted)">
										{link.url.replace(/^https:\/\//, "")}
									</div>
								</div>

								<svg
									class="h-4 w-4 flex-shrink-0 text-(--text-muted) transition-all duration-300 group-hover:translate-x-1 group-hover:text-(--primary-color)"
									fill="none"
									viewBox="0 0 24 24"
									stroke="currentColor"
									aria-hidden="true"
								>
									<path
										stroke-linecap="round"
										stroke-linejoin="round"
										stroke-width={2}
										d="M7 17L17 7M17 7H7M17 7v10"
									/>
								</svg>
							</a>
						))}
				</div>
			</section>
		))
	}
</div>

<script is:inline>
	document.querySelectorAll(".sns-links a[href]").forEach(function (link) {
		link.addEventListener("click", function () {
			window.posthog?.capture("sns_link_clicked", {
				platform: link.getAttribute("aria-label"),
				url: link.getAttribute("href"),
			});
		});
	});
</script>
