---
import SnsLinks from "@/components/SnsLinks.astro";
import { SITE } from "@/config/site";
import Layout from "@/layouts/Layout.astro";
---

<Layout
	title={`Links | ${SITE.name}`}
	description="ta93abeのSNS・ソーシャルメディアへのリンク集です。"
>
	<main class="mx-auto max-w-2xl px-6 py-16">
		<header class="mb-12 pb-2">
			<h1 class="mb-2 font-display text-3xl font-bold text-(--text-primary)">
				{SITE.author}
			</h1>
			<p class="mb-4 text-sm text-(--text-muted)">@ta93abe</p>
			<p class="text-(--text-secondary)">
				開発・デザイン・音楽など、いろいろな場所で活動しています。
			</p>
		</header>

		<SnsLinks />

		<section class="mt-16 pt-6 text-center">
			<p class="mb-4 text-sm text-(--text-secondary)">
				最新の活動は主に X（@ta93abe_）で発信しています。
			</p>
			<a
				href="https://x.com/ta93abe_"
				target="_blank"
				rel="noopener noreferrer"
				class="inline-flex items-center gap-2 bg-(--bg-secondary) px-5 py-2.5 text-sm text-(--text-primary) transition-colors hover:bg-(--bg-tertiary)"
			>
				<svg viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor" aria-hidden="true">
					<path d="M18.901 1.153h3.68l-8.04 9.19L24 22.846h-7.406l-5.8-7.584-6.638 7.584H.474l8.6-9.83L0 1.154h7.594l5.243 6.932ZM17.61 20.644h2.039L6.486 3.24H4.298Z"/>
				</svg>
				X でフォローする
			</a>
		</section>
	</main>
</Layout>
