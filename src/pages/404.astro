---
import { SITE } from "../config/site";
import Layout from "../layouts/Layout.astro";
---

<Layout
  title={`404 - ページが見つかりません | ${SITE.name}`}
  description="お探しのページは見つかりませんでした。"
>
  <main class="flex min-h-screen items-center justify-center px-6">
    <div class="text-center">
      <!-- 404 大きな数字 -->
      <div class="mb-8">
        <h1
          class="bg-gradient-to-r from-[var(--primary-color)] to-[var(--accent-color)] bg-clip-text text-6xl font-bold text-transparent sm:text-8xl md:text-9xl"
        >
          404
        </h1>
      </div>

      <!-- エラーメッセージ -->
      <div class="mb-8">
        <h2 class="mb-4 text-3xl font-bold text-[var(--text-primary)]">
          ページが見つかりません
        </h2>
        <p class="mx-auto max-w-md text-[var(--text-secondary)]">
          お探しのページは存在しないか、移動または削除された可能性があります。
        </p>
      </div>

      <!-- アクションボタン -->
      <div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a
          href="/"
          class="rounded-full bg-gradient-to-r from-[var(--primary-color)] to-[var(--accent-color)] px-6 py-3 font-semibold text-white shadow-lg transition-all hover:scale-105 hover:shadow-xl hover:shadow-[var(--primary-color)]/25"
        >
          ホームに戻る
        </a>
        <button
          type="button"
          id="history-back-button"
          class="rounded-full border-2 border-[var(--border-color)] px-6 py-3 font-semibold text-[var(--text-secondary)] transition-all hover:border-[var(--primary-color)]/50 hover:bg-[var(--bg-tertiary)]"
          aria-label="前のページに戻る"
        >
          前のページへ
        </button>
      </div>

      <!-- 装飾的な要素 -->
      <div class="mt-16 text-6xl text-[var(--text-muted)] opacity-50" aria-hidden="true">🔍</div>
    </div>
  </main>
</Layout>

<script>
  const backButton = document.getElementById("history-back-button");
  backButton?.addEventListener("click", () => {
    try {
      if (
        document.referrer &&
        new URL(document.referrer).origin === window.location.origin
      ) {
        window.history.back();
      } else {
        window.location.href = "/";
      }
    } catch (e) {
      console.error("Failed to go back:", e);
      window.location.href = "/";
    }
  });
</script>
