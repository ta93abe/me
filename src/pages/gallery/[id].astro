---
import { getCollection, render } from "astro:content";
import MediaTypeBadge from "@/components/creative/MediaTypeBadge.astro";
import PieceMedia from "@/components/creative/PieceMedia.astro";
import { SITE } from "@/config/site";
import Layout from "@/layouts/Layout.astro";
import type { MediaType } from "@/utils/creative-media";
import { formatDate } from "@/utils/date";
import { stringifySchema } from "@/utils/schema";

export async function getStaticPaths() {
	const pieces = await getCollection("gallery");
	return pieces.map((piece) => ({
		params: { id: piece.id },
		props: { piece },
	}));
}

const { piece } = Astro.props;
const { Content } = await render(piece);
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = piece.data.coverImage
	? new URL(piece.data.coverImage.src, Astro.site)
	: new URL("/og/default.png", Astro.site);

const schemaType =
	piece.data.mediaType === "music"
		? "MusicComposition"
		: piece.data.mediaType === "photo"
			? "Photograph"
			: piece.data.mediaType === "project"
				? "SoftwareApplication"
				: "VisualArtwork";

const pieceSchema = {
	"@context": "https://schema.org",
	"@type": schemaType,
	name: piece.data.title,
	description: piece.data.excerpt,
	image: ogImageURL.href,
	...(piece.data.audio ? { audio: new URL(piece.data.audio, Astro.site).href } : {}),
	keywords: piece.data.tags?.join(", "),
	author: {
		"@type": "Person",
		name: SITE.author,
		url: Astro.site?.href,
	},
	url: canonicalURL.href,
	inLanguage: SITE.lang,
	dateCreated: piece.data.completedDate?.toISOString(),
};
---

<Layout
	title={`${piece.data.title} | Gallery | ${SITE.name}`}
	description={piece.data.excerpt}
	ogType="article"
	ogImage={ogImageURL.href}
	ogImageAlt={piece.data.title}
>
	<Fragment slot="head">
		<meta property="article:author" content={SITE.author} />
		<script
			type="application/ld+json"
			set:html={stringifySchema(pieceSchema)}
		/>
	</Fragment>
	<main class="gallery-detail" data-media-type={piece.data.mediaType}>
		<div class="gallery-detail-nav">
			<a href="/gallery" class="gallery-back">← 一覧へ戻る</a>
		</div>

		<figure class="gallery-detail-figure">
			<div class:list={["gallery-detail-media", `is-${piece.data.mediaType}`]}>
				<PieceMedia
					mediaType={piece.data.mediaType as MediaType}
					title={piece.data.title}
					coverImage={piece.data.coverImage}
					audio={piece.data.audio}
					variant="gallery"
				/>
			</div>
			<figcaption class="gallery-detail-caption">
				<div class="gallery-detail-meta">
					<MediaTypeBadge mediaType={piece.data.mediaType as MediaType} />
					{
						piece.data.completedDate && (
							<time datetime={piece.data.completedDate.toISOString()}>
								{formatDate(piece.data.completedDate)}
							</time>
						)
					}
				</div>
				<h1 class="gallery-detail-title font-display">{piece.data.title}</h1>
				<p class="gallery-detail-excerpt">{piece.data.excerpt}</p>
			</figcaption>
		</figure>

		<article class="gallery-detail-body prose prose-lg max-w-none">
			<Content />
		</article>
	</main>
</Layout>

<style>
	.gallery-detail {
		padding: 6.5rem 0 5rem;
	}

	.gallery-detail-nav {
		max-width: 56rem;
		margin: 0 auto;
		padding: 0 1.5rem 2rem;
	}

	.gallery-back {
		display: inline-block;
		margin-top: 1rem;
		font-size: 0.9375rem;
		color: var(--text-secondary);
		text-decoration: none;
		transition: color 0.2s ease;
	}

	.gallery-back:hover {
		color: var(--primary-color);
	}

	.gallery-detail-figure {
		margin: 0 0 3.5rem;
	}

	.gallery-detail-media {
		width: 100%;
		aspect-ratio: 21 / 9;
		overflow: hidden;
	}

	.gallery-detail-media.is-music,
	.gallery-detail-media.is-project {
		aspect-ratio: 16 / 9;
	}

	@media (max-width: 768px) {
		.gallery-detail-media {
			aspect-ratio: 4 / 3;
		}
	}

	.gallery-detail-caption {
		max-width: 40rem;
		margin: 0 auto;
		padding: 2rem 1.5rem 0;
	}

	.gallery-detail-meta {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.85rem;
		margin-bottom: 1rem;
		font-size: 0.875rem;
		color: var(--text-muted);
	}

	.gallery-detail-title {
		margin: 0 0 1rem;
		font-size: clamp(2rem, 6vw, 3.25rem);
		font-weight: 700;
		line-height: 1.2;
		color: var(--text-primary);
	}

	.gallery-detail-excerpt {
		margin: 0;
		font-size: 1.0625rem;
		line-height: 1.85;
		color: var(--text-secondary);
	}

	.gallery-detail-body {
		max-width: 40rem;
		margin: 0 auto;
		padding: 0 1.5rem;
	}
</style>

<script>
	const copyIcon = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"><path d="M7 3.5A1.5 1.5 0 0 1 8.5 2h3.879a1.5 1.5 0 0 1 1.06.44l3.122 3.12A1.5 1.5 0 0 1 17 6.622V12.5a1.5 1.5 0 0 1-1.5 1.5h-1v-3.379a3 3 0 0 0-.879-2.121L10.5 5.379A3 3 0 0 0 8.379 4.5H7v-1Z" /><path d="M4.5 6A1.5 1.5 0 0 0 3 7.5v9A1.5 1.5 0 0 0 4.5 18h7a1.5 1.5 0 0 0 1.5-1.5v-5.879a1.5 1.5 0 0 0-.44-1.06L9.44 6.439A1.5 1.5 0 0 0 8.378 6H4.5Z" /></svg>`;
	const copiedIcon = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z" clip-rule="evenodd" /></svg>`;

	document.querySelectorAll(".prose pre").forEach((pre) => {
		const button = document.createElement("button");
		button.className = "copy-button";
		button.innerHTML = copyIcon;
		button.addEventListener("click", async () => {
			const code = pre.querySelector("code");
			if (code) {
				await navigator.clipboard.writeText(code.textContent || "");
				button.classList.add("copied");
				button.innerHTML = copiedIcon;
				setTimeout(() => {
					button.classList.remove("copied");
					button.innerHTML = copyIcon;
				}, 2000);
			}
		});
		pre.appendChild(button);
	});
</script>

<script>
	window.posthog?.capture("gallery_piece_viewed", {
		piece_title: document.title,
		piece_url: window.location.href,
		media_type: document.querySelector("[data-media-type]")?.getAttribute("data-media-type"),
	});
</script>
