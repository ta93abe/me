---
import { getCollection } from "astro:content";
import MediaTypeBadge from "@/components/creative/MediaTypeBadge.astro";
import PieceMedia from "@/components/creative/PieceMedia.astro";
import EmptyState from "@/components/ui/EmptyState.astro";
import { SITE } from "@/config/site";
import Layout from "@/layouts/Layout.astro";
import type { MediaType } from "@/utils/creative-media";
import { formatDate } from "@/utils/date";

const pieces = await getCollection("gallery");

const sorted = [...pieces].toSorted((a, b) => {
	const aTime = a.data.completedDate?.getTime() ?? 0;
	const bTime = b.data.completedDate?.getTime() ?? 0;
	return bTime - aTime;
});
---

<Layout
	title={`Gallery | ${SITE.name}`}
	description="絵・写真・音楽の完成作品と、ポートフォリオプロジェクトを並べたギャラリー。"
>
	<main class="gallery-page">
		<header class="gallery-header">
			<h1 class="gallery-title font-display">ギャラリー</h1>
			<p class="gallery-lead">
				絵・写真・音楽の完成作品と、<br />
				手がけたプロジェクトを余白を残して置いています。
			</p>
		</header>

		{
			sorted.length === 0 ? (
				<EmptyState
					title="展示はまだありません"
					description="完成した作品が揃い次第、ここに並びます。"
				/>
			) : (
				<section class="gallery-wall" aria-label="作品一覧">
					{sorted.map((piece) => (
						<a
							href={`/gallery/${piece.id}`}
							class="gallery-piece"
							data-item
							data-media-type={piece.data.mediaType}
						>
							<div class="gallery-media">
								<PieceMedia
									mediaType={piece.data.mediaType as MediaType}
									title={piece.data.title}
									coverImage={piece.data.coverImage}
									audio={piece.data.audio}
									variant="card"
								/>
							</div>
							<div class="gallery-caption">
								<div class="gallery-caption-meta">
									<MediaTypeBadge mediaType={piece.data.mediaType as MediaType} />
									{piece.data.completedDate && (
										<time
											class="gallery-piece-date"
											datetime={piece.data.completedDate.toISOString()}
										>
											{formatDate(piece.data.completedDate)}
										</time>
									)}
								</div>
								<h2 class="gallery-piece-title">{piece.data.title}</h2>
								<p class="gallery-piece-excerpt">{piece.data.excerpt}</p>
							</div>
						</a>
					))}
				</section>
			)
		}
	</main>
</Layout>

<style>
	.gallery-page {
		max-width: 68rem;
		margin: 0 auto;
		padding: 6rem 1.5rem 4rem;
	}

	.gallery-header {
		margin-bottom: 3rem;
	}

	.gallery-title {
		margin: 0 0 0.75rem;
		font-size: clamp(2rem, 6vw, 2.75rem);
		font-weight: 700;
		line-height: 1.2;
		color: var(--text-primary);
	}

	.gallery-lead {
		margin: 0;
		max-width: 36rem;
		font-size: 1rem;
		line-height: 1.8;
		color: var(--text-secondary);
	}

	.gallery-wall {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1.5rem;
	}

	@media (min-width: 640px) {
		.gallery-wall {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (min-width: 1024px) {
		.gallery-wall {
			grid-template-columns: repeat(3, 1fr);
		}
	}

	.gallery-piece {
		display: flex;
		flex-direction: column;
		text-decoration: none;
		color: inherit;
	}

	.gallery-media {
		overflow: hidden;
		aspect-ratio: 4 / 3;
	}

	.gallery-caption {
		padding: 0.75rem 0 0;
	}

	.gallery-caption-meta {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		margin-bottom: 0.5rem;
	}

	.gallery-piece-title {
		margin: 0 0 0.35rem;
		font-size: 1.125rem;
		font-weight: 700;
		line-height: 1.4;
		color: var(--text-primary);
	}

	.gallery-piece-excerpt {
		margin: 0;
		font-size: 0.9375rem;
		line-height: 1.7;
		color: var(--text-secondary);
	}

	.gallery-piece-date {
		flex-shrink: 0;
		font-size: 0.8125rem;
		color: var(--text-muted);
	}
</style>

<script is:inline>
	document.querySelectorAll(".gallery-piece").forEach(function (piece) {
		piece.addEventListener("click", function () {
			window.posthog?.capture("gallery_piece_clicked", {
				piece_title: piece.querySelector(".gallery-piece-title")?.textContent?.trim(),
				piece_href: piece.getAttribute("href"),
				media_type: piece.getAttribute("data-media-type"),
			});
		});
	});
</script>
