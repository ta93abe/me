---
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import Badge from "@/components/ui/Badge.astro";
import Tag from "@/components/ui/Tag.astro";
import { SITE } from "@/config/site";
import Layout from "@/layouts/Layout.astro";
import { formatDate } from "@/utils/date";

const books = await getCollection("books");

const sortedBooks = [...books].toSorted((a, b) => {
	const aTime = a.data.finishedDate?.getTime() ?? 0;
	const bTime = b.data.finishedDate?.getTime() ?? 0;
	return bTime - aTime;
});
---

<Layout
  title={`Bookshelf | ${SITE.name}`}
  description="読書記録と書評の一覧。読んだ本や積読のメモをまとめています。"
>
  <main class="mx-auto max-w-6xl px-6 py-12">
    <h1 class="mb-12 text-4xl font-bold text-(--text-primary)">Bookshelf</h1>

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        sortedBooks.map((book) => (
          <a
            href={`/bookshelf/${book.id}`}
            class="group block overflow-hidden"
          >
            <div class="aspect-[3/4] overflow-hidden">
              <Image
                src={book.data.coverImage}
                alt={`${book.data.title} cover`}
                class="h-full w-full object-cover"
              />
            </div>
            <div class="pt-3">
              <div class="mb-3 flex flex-wrap items-center gap-2">
                <Badge variant={book.data.status} />
                {book.data.category && <Tag>{book.data.category}</Tag>}
              </div>
              <h2 class="mb-1 text-xl font-bold text-(--text-primary)">{book.data.title}</h2>
              <p class="mb-2 text-sm text-(--text-secondary)">{book.data.author}</p>
              {book.data.finishedDate && (
                <p class="mb-2 text-xs text-(--text-muted)">
                  読了日: {formatDate(book.data.finishedDate)}
                </p>
              )}
              <p class="mb-3 text-sm text-(--text-secondary)">{book.data.excerpt}</p>
              {book.data.rating && (
                <p class="mt-3 text-xs text-(--text-muted)">
                  評価: {book.data.rating} / 5
                </p>
              )}
            </div>
          </a>
        ))
      }
    </div>
  </main>
</Layout>
