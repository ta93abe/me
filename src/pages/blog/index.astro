---
import { getCollection } from "astro:content";
import FilterSort from "@/components/FilterSort.astro";
import Tag from "@/components/ui/Tag.astro";
import { SITE } from "@/config/site";
import Layout from "@/layouts/Layout.astro";
import { formatDate } from "@/utils/date";

const blogPosts = await getCollection("blog");
const sortedPosts = blogPosts.toSorted(
	(a, b) => b.data.date.getTime() - a.data.date.getTime(),
);

// すべてのタグを収集
const allTags = blogPosts.flatMap((post) => post.data.tags ?? []);
---

<Layout
  title={`Blog | ${SITE.name}`}
  description="技術ブログ。日々の学びや開発の記録を共有しています。"
>
  <link
    slot="head"
    rel="alternate"
    type="application/rss+xml"
    title="ta93abe | Blog RSS Feed"
    href="/rss.xml"
  />
  <main class="mx-auto max-w-3xl px-6 py-12">
    <div class="mb-12 flex items-center justify-between">
      <div>
        <h1 class="font-display text-4xl font-bold tracking-tight text-(--text-primary)">Blog</h1>
        <p class="mt-2 text-(--text-secondary)">技術ブログ。日々の学びや開発の記録を共有しています。</p>
      </div>
      <a
        href="/rss.xml"
        id="rss-feed-link"
        class="inline-flex items-center gap-1.5 text-sm text-(--text-muted) transition-opacity hover:opacity-60"
        aria-label="RSS Feed"
      >
        <svg
          class="size-4"
          fill="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            d="M6.503 20.752c0 1.794-1.456 3.248-3.251 3.248-1.796 0-3.252-1.454-3.252-3.248 0-1.794 1.456-3.248 3.252-3.248 1.795.001 3.251 1.454 3.251 3.248zm-6.503-12.572v4.811c6.05.062 10.96 4.966 11.022 11.009h4.817c-.062-8.71-7.118-15.758-15.839-15.82zm0-3.368c10.58.046 19.152 8.594 19.183 19.188h4.817c-.03-13.231-10.755-23.954-24-24v4.812z"
          ></path>
        </svg>
        <span>RSS</span>
      </a>
    </div>

    <!-- フィルタリング・ソート -->
    <FilterSort tags={allTags} containerId="blog-list" />

    <div id="blog-list" class="flex flex-col">
      {
        sortedPosts.map((post) => (
          <article
            class="group border-b border-(--border-color) last:border-b-0"
            data-item
            data-tags={(post.data.tags ?? []).join(",")}
            data-date={post.data.date.toISOString()}
            data-title={post.data.title}
          >
            <a
              href={`/blog/${post.id}`}
              class="block py-8 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-(--primary-color)"
            >
              <div class="flex flex-col gap-3 sm:flex-row sm:gap-8">
                <time class="shrink-0 font-sans text-sm tracking-wide text-(--text-muted) sm:w-28 sm:pt-1">
                  {formatDate(post.data.date)}
                  {post.data.updatedDate && (
                    <span class="mt-1 block text-xs">
                      更新 {formatDate(post.data.updatedDate)}
                    </span>
                  )}
                </time>
                <div class="min-w-0 flex-1">
                  <h2 class="mb-2 font-display text-xl font-bold text-(--text-primary) transition-colors group-hover:text-(--primary-color) sm:text-2xl">
                    {post.data.title}
                  </h2>
                  <p class="mb-3 text-sm leading-relaxed text-(--text-secondary) sm:text-base">
                    {post.data.excerpt}
                  </p>
                  {post.data.tags && post.data.tags.length > 0 && (
                    <div class="flex flex-wrap gap-x-3 gap-y-1">
                      {post.data.tags.map((tag) => (
                        <Tag>#{tag}</Tag>
                      ))}
                    </div>
                  )}
                </div>
              </div>
            </a>
          </article>
        ))
      }
    </div>
  </main>
</Layout>

<script is:inline>
  document.getElementById("rss-feed-link")?.addEventListener("click", function() {
    window.posthog?.capture("rss_feed_clicked", { page: "blog" });
  });

  document.querySelectorAll("[data-filter-sort] .filter-chip").forEach(function(chip) {
    chip.addEventListener("click", function() {
      var tag = chip.dataset.tag;
      if (tag && tag !== "all") {
        window.posthog?.capture("blog_tag_filtered", { tag: tag });
      }
    });
  });
</script>
