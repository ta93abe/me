---
import { getCollection } from "astro:content";
import MediaTypeBadge from "@/components/creative/MediaTypeBadge.astro";
import PieceMedia from "@/components/creative/PieceMedia.astro";
import EmptyState from "@/components/ui/EmptyState.astro";
import { SITE } from "@/config/site";
import Layout from "@/layouts/Layout.astro";
import type { MediaType } from "@/utils/creative-media";
import { formatDate } from "@/utils/date";

const pieces = await getCollection("atelier");

const sorted = [...pieces].toSorted((a, b) => {
	const aTime = a.data.date?.getTime() ?? 0;
	const bTime = b.data.date?.getTime() ?? 0;
	return bTime - aTime;
});

const statusLabel: Record<string, string> = {
	wip: "作業中",
	practice: "練習",
	sketch: "スケッチ",
};
---

<Layout
	title={`Atelier | ${SITE.name}`}
	description="絵・写真・音楽の作業中や練習を雑多に置くアトリエ。"
>
	<main class="atelier-page">
		<header class="atelier-header">
			<h1 class="atelier-title font-display">アトリエ</h1>
			<p class="atelier-lead">
				絵・写真・音楽の練習や途中経過を、作業机の上みたいに雑多に置いています。
			</p>
		</header>

		{
			sorted.length === 0 ? (
				<EmptyState
					title="まだ何も置いていません"
					description="習作や作業メモが増えたら、ここに散らばっていきます。"
				/>
			) : (
				<div class="atelier-board">
					{sorted.map((piece) => (
						<a
							href={`/atelier/${piece.id}`}
							class="atelier-scrap"
							data-item
							data-media-type={piece.data.mediaType}
						>
							<div class="atelier-scrap-media">
								<PieceMedia
									mediaType={piece.data.mediaType as MediaType}
									title={piece.data.title}
									coverImage={piece.data.coverImage}
									audio={piece.data.audio}
									variant="card"
								/>
							</div>
							<div class="atelier-scrap-body">
								<div class="atelier-scrap-meta">
									<MediaTypeBadge mediaType={piece.data.mediaType as MediaType} />
									<span class="atelier-status">
										{statusLabel[piece.data.status] ?? piece.data.status}
									</span>
									{piece.data.date && (
										<time datetime={piece.data.date.toISOString()}>
											{formatDate(piece.data.date)}
										</time>
									)}
								</div>
								<h2 class="atelier-scrap-title">{piece.data.title}</h2>
								<p class="atelier-scrap-excerpt">{piece.data.excerpt}</p>
							</div>
						</a>
					))}
				</div>
			)
		}
	</main>
</Layout>

<style>
	.atelier-page {
		max-width: 68rem;
		margin: 0 auto;
		padding: 6rem 1.5rem 4rem;
	}

	.atelier-header {
		margin-bottom: 3rem;
	}

	.atelier-title {
		margin: 0 0 0.75rem;
		font-size: clamp(2rem, 6vw, 2.75rem);
		font-weight: 700;
		line-height: 1.2;
		color: var(--text-primary);
	}

	.atelier-lead {
		margin: 0;
		max-width: 36rem;
		font-size: 1rem;
		line-height: 1.8;
		color: var(--text-secondary);
	}

	.atelier-board {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1.5rem;
	}

	@media (min-width: 640px) {
		.atelier-board {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (min-width: 1024px) {
		.atelier-board {
			grid-template-columns: repeat(3, 1fr);
		}
	}

	.atelier-scrap {
		display: flex;
		flex-direction: column;
		text-decoration: none;
		color: inherit;
	}

	.atelier-scrap-media {
		overflow: hidden;
		aspect-ratio: 4 / 3;
	}

	.atelier-scrap-body {
		padding: 0.75rem 0 0;
	}

	.atelier-scrap-meta {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.5rem 0.75rem;
		margin-bottom: 0.5rem;
		font-size: 0.8125rem;
		color: var(--text-muted);
	}

	.atelier-status {
		color: var(--text-secondary);
	}

	.atelier-scrap-title {
		margin: 0 0 0.35rem;
		font-size: 1.125rem;
		font-weight: 700;
		line-height: 1.45;
		color: var(--text-primary);
	}

	.atelier-scrap-excerpt {
		margin: 0;
		font-size: 0.9375rem;
		line-height: 1.7;
		color: var(--text-secondary);
	}
</style>

<script>
	document.querySelectorAll(".atelier-scrap").forEach((scrap) => {
		scrap.addEventListener("click", () => {
			window.posthog?.capture("atelier_piece_clicked", {
				piece_title: scrap.querySelector(".atelier-scrap-title")?.textContent?.trim(),
				piece_href: scrap.getAttribute("href"),
				media_type: scrap.getAttribute("data-media-type"),
			});
		});
	});
</script>
