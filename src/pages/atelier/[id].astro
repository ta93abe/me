---
import { getCollection, render } from "astro:content";
import MediaTypeBadge from "@/components/creative/MediaTypeBadge.astro";
import PieceMedia from "@/components/creative/PieceMedia.astro";
import { SITE } from "@/config/site";
import Layout from "@/layouts/Layout.astro";
import type { MediaType } from "@/utils/creative-media";
import { formatDate } from "@/utils/date";
import { stringifySchema } from "@/utils/schema";

export async function getStaticPaths() {
	const pieces = await getCollection("atelier");
	return pieces.map((piece) => ({
		params: { id: piece.id },
		props: { piece },
	}));
}

const { piece } = Astro.props;
const { Content } = await render(piece);
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = piece.data.coverImage
	? new URL(piece.data.coverImage.src, Astro.site)
	: new URL("/og/default.png", Astro.site);

const statusLabel: Record<string, string> = {
	wip: "作業中",
	practice: "練習",
	sketch: "スケッチ",
};

const schemaType =
	piece.data.mediaType === "music"
		? "MusicComposition"
		: piece.data.mediaType === "photo"
			? "Photograph"
			: "VisualArtwork";

const pieceSchema = {
	"@context": "https://schema.org",
	"@type": schemaType,
	name: piece.data.title,
	description: piece.data.excerpt,
	image: ogImageURL.href,
	...(piece.data.audio ? { audio: new URL(piece.data.audio, Astro.site).href } : {}),
	keywords: piece.data.tags?.join(", "),
	author: {
		"@type": "Person",
		name: SITE.author,
		url: Astro.site?.href,
	},
	url: canonicalURL.href,
	inLanguage: SITE.lang,
	creativeWorkStatus: piece.data.status,
};
---

<Layout
	title={`${piece.data.title} | Atelier | ${SITE.name}`}
	description={piece.data.excerpt}
	ogType="article"
	ogImage={ogImageURL.href}
	ogImageAlt={piece.data.title}
>
	<Fragment slot="head">
		<meta property="article:author" content={SITE.author} />
		<script
			type="application/ld+json"
			set:html={stringifySchema(pieceSchema)}
		/>
	</Fragment>
	<main class="atelier-detail">
		<a href="/atelier" class="atelier-back">← アトリエへ戻る</a>

		<header class="atelier-detail-header">
			<div class="atelier-detail-meta">
				<MediaTypeBadge mediaType={piece.data.mediaType as MediaType} />
				<span class="atelier-status">
					{statusLabel[piece.data.status] ?? piece.data.status}
				</span>
				{
					piece.data.date && (
						<time datetime={piece.data.date.toISOString()}>
							{formatDate(piece.data.date)}
						</time>
					)
				}
			</div>
			<h1 class="atelier-detail-title font-display">{piece.data.title}</h1>
			<p class="atelier-detail-excerpt">{piece.data.excerpt}</p>
			{
				piece.data.tags && piece.data.tags.length > 0 && (
					<ul class="atelier-tags">
						{piece.data.tags.map((tag) => (
							<li>{tag}</li>
						))}
					</ul>
				)
			}
		</header>

		<div class:list={["atelier-detail-media", `is-${piece.data.mediaType}`]}>
			<PieceMedia
				mediaType={piece.data.mediaType as MediaType}
				title={piece.data.title}
				coverImage={piece.data.coverImage}
				audio={piece.data.audio}
				variant="detail"
			/>
		</div>

		<article class="prose prose-lg max-w-none">
			<Content />
		</article>
	</main>
</Layout>

<style>
	.atelier-detail {
		max-width: 48rem;
		margin: 0 auto;
		padding: 6.5rem 1.5rem 4rem;
	}

	.atelier-back {
		display: inline-block;
		margin: 1rem 0 1.5rem;
		font-size: 0.9375rem;
		color: var(--text-secondary);
		text-decoration: none;
		transition: color 0.2s ease;
	}

	.atelier-back:hover {
		color: var(--primary-color);
	}

	.atelier-detail-header {
		margin-bottom: 2.5rem;
	}

	.atelier-detail-meta {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.75rem;
		margin-bottom: 1.25rem;
		font-size: 0.875rem;
		color: var(--text-muted);
	}

	.atelier-detail-media {
		margin-bottom: 2.5rem;
		overflow: hidden;
		aspect-ratio: 16 / 10;
	}

	.atelier-detail-media.is-music {
		aspect-ratio: 16 / 9;
	}

	.atelier-detail-title {
		margin: 0 0 1rem;
		font-size: clamp(2rem, 5vw, 2.75rem);
		font-weight: 700;
		line-height: 1.25;
		color: var(--text-primary);
	}

	.atelier-detail-excerpt {
		margin: 0 0 1.25rem;
		font-size: 1.0625rem;
		line-height: 1.85;
		color: var(--text-secondary);
	}

	.atelier-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.atelier-tags li {
		font-size: 0.8125rem;
		color: var(--text-muted);
	}
</style>

<script is:inline>
	window.posthog?.capture("atelier_piece_viewed", {
		piece_title: document.title,
		piece_url: window.location.href,
	});
</script>
